{
  "name": "desktop-file-integrity",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json",
    "build": "npm run build:electron && vite build && electron-builder",
    "build:win": "npm run build:electron && vite build && electron-builder --win",
    "build:mac": "npm run build:electron && vite build && electron-builder --mac",
    "build:linux": "npm run build:electron && vite build && electron-builder --linux",
    "build:all": "npm run build:electron && vite build && electron-builder -mwl",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "npm run build:electron && npx electron dist-electron/electron/main.js"
  },
  "main": "dist-electron/electron/main.js",
  "dependencies": {
    "@bsv/sdk": "^1.6.11",
    "dotenv": "^17.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^7.6.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^28.3.3",
    "electron-builder": "^26.4.0",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "typescript": "^6.0.2",
    "vite": "^7.0.0"
  },
  "build": {
    "appId": "com.bsv.desktopfileintegrity",
    "productName": "Desktop File Integrity",
    "files": [
      "dist/**/*",
      "dist-electron/electron/*.js",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
